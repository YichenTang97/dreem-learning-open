{
  "n_class": 5,
  "output_mode": "many",
  "eval_output_mode": "many",
  "type": "modulo_net",
  "encoders": {
    "eeg": {
      "type": "CNNMaxPoolEpochEncoder",
      "args": {
        "conv_layers": [
          {
            "in_channels": 1,
            "out_channels": 16,
            "kernel_size": 64,
            "stride": 4,
            "padding": 32,
            "bias": false,
            "activation": "elu",
            "batch_norm": true,
            "dropout": 0.25
          },
          {
            "in_channels": 16,
            "out_channels": 64,
            "kernel_size": 16,
            "stride": 4,
            "padding": 8,
            "bias": false,
            "activation": "elu",
            "batch_norm": true,
            "dropout": 0.25
          },
          {
            "in_channels": 64,
            "out_channels": 128,
            "kernel_size": 8,
            "stride": 2,
            "padding": 4,
            "bias": false,
            "activation": "elu",
            "batch_norm": true,
            "dropout": 0.0
          }
        ]
      }
    }
  },
  "reducer": {
    "type": "PoolReducer",
    "args": {
      "pool_operation": "max"
    }
  },
  "sequence_encoder": {
    "type": "LSTMSequenceEncoder",
    "args": {
      "cells": 128,
      "bidir": false,
      "dropout": 0.5,
      "layers": 2
    }
  }
}
